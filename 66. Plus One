# This problem reminded me of Roman to Integer because both require handling a carry while processing digits.
# Although the idea seems simple, correctly propagating the carry through consecutive 9s is the main challenge.
# A common mistake is forgetting that the carry can continue across multiple digits, or even create a new leading digit.

class Solution:
    def plusOne(self, digits: List[int]) -> List[int]:
        digits = digits[::-1]
        carryFlag = 1
        i = 0
        while carryFlag:
            if i < len(digits):
                if digits[i] == 9:
                    #carry activated
                    digits[i] = 0
                else:
                    digits[i] += 1
                    carryFlag = 0
            else:
                digits.append(1)
                one = 0
            i += 1
        return digits[::-1]
